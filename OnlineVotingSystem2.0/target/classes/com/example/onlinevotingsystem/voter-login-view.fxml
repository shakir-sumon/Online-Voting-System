<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.onlinevotingsystem.VoterLoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #232526, #414345);">

    <VBox alignment="CENTER" spacing="15"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <Label text="Voter Login"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" />

        <TextField fx:id="voterIdField"
                   promptText="Voter ID"
                   maxWidth="400"
                   style="-fx-background-radius: 20;" />

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       maxWidth="400"
                       style="-fx-background-radius: 20;" />

        <Button text="Login"
                onAction="#handleLogin"
                prefWidth="200" prefHeight="45"
                style="-fx-background-radius: 20; -fx-font-weight: bold;" />

        <Label fx:id="messageLabel"
               style="-fx-text-fill: white;" />

    </VBox>

</AnchorPane>
