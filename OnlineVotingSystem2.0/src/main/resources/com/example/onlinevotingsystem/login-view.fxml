<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.onlinevotingsystem.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #141e30, #243b55);">

    <VBox alignment="CENTER" spacing="20"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <Label text="Online Voting System"
               style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;" />

        <Button text="Admin Login"
                onAction="#openAdminLogin"
                prefWidth="300" prefHeight="50"
                style="-fx-background-radius: 25; -fx-font-size: 14; -fx-font-weight: bold;" />

        <Button text="Voter Login"
                onAction="#openVoterLogin"
                prefWidth="300" prefHeight="50"
                style="-fx-background-radius: 25; -fx-font-size: 14; -fx-font-weight: bold;" />

    </VBox>

</AnchorPane>
