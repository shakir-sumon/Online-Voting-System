<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.onlinevotingsystem.AdminLoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #1e3c72, #2a5298);">

    <StackPane AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0">

        <VBox alignment="CENTER" spacing="15">

            <Label text="Admin Login"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" />

            <TextField fx:id="usernameField"
                       promptText="Admin ID"
                       maxWidth="400" />

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           maxWidth="400" />

            <Button text="Login"
                    onAction="#handleLogin"
                    prefWidth="200"
                    prefHeight="45" />

            <Label fx:id="messageLabel"
                   style="-fx-text-fill: white;" />

        </VBox>

    </StackPane>

</AnchorPane>

